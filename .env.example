# Development environment variables for mini-apty

# Secret used to sign JWT tokens. Set to a secure random value in production.
JWT_SECRET=change_me_to_a_secure_value

# Database connection string for Prisma SQLite. 
# For local development, defaults to a file-based DB in the repo.
# For Docker, the path is relative to the container working directory (/app).
DATABASE_URL=file:./apps/backend/prisma/dev.db
